PORT=3001

# Orígenes permitidos (coma-separados para múltiples o * para todos)
# En producción: poner la URL de Vercel
CORS_ORIGIN=http://localhost:5173

# LLM — Groq es gratuito sin tarjeta de crédito
# Obtener en: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Fuentes de datos históricos (opcionales, tienen fallback)
# https://dayinhistory.dev — gratis: 10 req/h, premium: 1000 req/h
DAY_IN_HISTORY_API_KEY=
# https://api-ninjas.com — fallback si Day in History falla
API_NINJAS_KEY=

# Webhook para registrar eventos favoritos
# Opciones: https://pipedream.com | https://requestbin.com | https://webhook.site
REGISTER_WEBHOOK_URL=https://httpbin.org/post
